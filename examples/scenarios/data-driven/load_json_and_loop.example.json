{
  "name": "load-json-and-loop",
  "variables": {},
  "steps": [
    {
      "action": "load_json",
      "path": "../../data/sample_accounts.json",
      "save_as": "accounts"
    },
    {
      "action": "foreach",
      "items": "{{accounts}}",
      "item_var": "account",
      "index_var": "account_index",
      "steps": [
        {
          "action": "print",
          "message": "第 {{account_index}} 个邮箱是 {{account.email}}，项目是 {{account.project}}"
        }
      ]
    },
    {
      "action": "dump_variables",
      "path": "../../output/examples/load-json-and-loop.variables.json"
    }
  ]
}
