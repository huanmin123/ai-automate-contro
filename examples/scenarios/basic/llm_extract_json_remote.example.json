{
  "name": "llm-extract-json-remote",
  "variables": {
    "raw_text": "邮箱: alpha@example.com\\n项目: project-a\\n状态: 可用"
  },
  "steps": [
    {
      "action": "llm_extract_json",
      "service": "remote_openai_compatible",
      "input": "{{raw_text}}",
      "schema_description": "输出 {\"email\": string, \"project\": string, \"status\": string}",
      "save_as": "parsed",
      "save_text_as": "raw_model_text"
    },
    {
      "action": "write_json",
      "path": "../../../output/examples/llm-extract-json-remote.json",
      "value": "{{parsed}}"
    }
  ]
}
