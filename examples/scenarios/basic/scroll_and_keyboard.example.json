{
  "name": "scroll-and-keyboard",
  "variables": {},
  "steps": [
    {
      "action": "open_browser",
      "name": "demo",
      "headed": true,
      "slow_mo_ms": 100
    },
    {
      "action": "goto",
      "browser": "demo",
      "url": "https://aijh.huanmin.top/"
    },
    {
      "action": "focus",
      "browser": "demo",
      "selector": "input[autocomplete='username']"
    },
    {
      "action": "keyboard_type",
      "browser": "demo",
      "value": "test-from-keyboard",
      "delay_ms": 50
    },
    {
      "action": "keyboard_press",
      "browser": "demo",
      "key": "Tab"
    },
    {
      "action": "keyboard_type",
      "browser": "demo",
      "value": "keyboard-password",
      "delay_ms": 50
    },
    {
      "action": "scroll_by",
      "browser": "demo",
      "delta_y": 300
    },
    {
      "action": "mouse_wheel",
      "browser": "demo",
      "delta_y": -300
    },
    {
      "action": "wait",
      "browser": "demo",
      "seconds": 3
    }
  ]
}
