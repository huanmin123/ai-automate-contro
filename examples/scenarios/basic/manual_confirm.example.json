{
  "variables": {
    "email": "test@example.com"
  },
  "steps": [
    {
      "action": "open_browser",
      "name": "receiver",
      "headed": true,
      "slow_mo_ms": 200,
      "timeout_ms": 15000
    },
    {
      "action": "goto",
      "browser": "receiver",
      "url": "https://aijh.huanmin.top/"
    },
    {
      "action": "manual_confirm",
      "prompt": "页面已经打开。手动完成前置操作后输入 y 继续: "
    },
    {
      "action": "fill",
      "browser": "receiver",
      "selector": "input[autocomplete='username']",
      "value": "{{email}}"
    },
    {
      "action": "wait",
      "browser": "receiver",
      "seconds": 5
    }
  ]
}
