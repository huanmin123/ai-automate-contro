{
  "name": "extract-table",
  "variables": {
    "table_demo_url": "data:text/html,<html><body><table><thead><tr><th>Name</th><th>Role</th></tr></thead><tbody><tr><td>Alice</td><td>Admin</td></tr><tr><td>Bob</td><td>Tester</td></tr></tbody></table></body></html>"
  },
  "steps": [
    {
      "action": "open_browser",
      "name": "demo",
      "headed": false
    },
    {
      "action": "goto",
      "browser": "demo",
      "url": "{{table_demo_url}}"
    },
    {
      "action": "extract_table",
      "browser": "demo",
      "row_selector": "tbody tr",
      "cell_selector": "td",
      "include_header": true,
      "header_selector": "thead th",
      "save_as": "table_rows"
    },
    {
      "action": "write_json",
      "path": "../../../output/examples/extract-table.json",
      "value": "{{table_rows}}"
    }
  ]
}
