{
  "name": "llm-chat-local-gateway",
  "variables": {
    "input_text": "请把这句话压缩成一句更短的话：自动化框架已经支持 OCR、文件读写和多页面控制。"
  },
  "steps": [
    {
      "action": "llm_chat",
      "service": "local_gateway",
      "messages": [
        {
          "role": "system",
          "content": "你是一个简洁的中文助手。"
        },
        {
          "role": "user",
          "content": "{{input_text}}"
        }
      ],
      "save_as": "llm_result",
      "save_text_as": "llm_text"
    },
    {
      "action": "write_json",
      "path": "../../../output/examples/llm-chat-local-gateway.json",
      "value": "{{llm_result}}"
    }
  ]
}
