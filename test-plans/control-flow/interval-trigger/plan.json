{
  "name": "interval-trigger",
  "automation_type": "browser",
  "variables": {},
  "steps": [
    {
      "action": "write",
      "type": "text",
      "path": "ticks.txt",
      "value": ""
    },
    {
      "action": "trigger",
      "type": "interval",
      "name": "inline_ticker",
      "every_seconds": 0.1,
      "run_immediately": true,
      "max_runs": 2,
      "overlap": "skip",
      "on_error": "fail_plan",
      "steps": [
        {
          "action": "write",
          "type": "text",
          "path": "ticks.txt",
          "value": "inline {{trigger_run_index}}\n",
          "append": true
        }
      ],
      "output": {
        "as": "inline_status"
      }
    },
    {
      "action": "trigger",
      "type": "interval",
      "name": "sub_plan_ticker",
      "every_seconds": 0.1,
      "run_immediately": true,
      "max_runs": 2,
      "overlap": "skip",
      "on_error": "fail_plan",
      "path": "sub-plans/tick-once-plan.json",
      "output": {
        "as": "sub_plan_status"
      }
    },
    {
      "action": "write",
      "type": "json",
      "path": "trigger-status.json",
      "value": {
        "inline": "{{inline_status}}",
        "sub_plan": "{{sub_plan_status}}"
      },
      "indent": 2
    }
  ]
}
