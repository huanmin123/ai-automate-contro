{
  "name": "desktop basic",
  "automation_type": "desktop",
  "variables": {},
  "steps": [
    {
      "action": "open_desktop",
      "name": "desktop",
      "backend": "auto",
      "output": {
        "as": "desktop_probe"
      }
    },
    {
      "action": "desktop_window",
      "desktop": "desktop",
      "type": "list",
      "path": "windows.json",
      "output": {
        "as": "desktop_windows"
      }
    },
    {
      "action": "desktop_capture",
      "desktop": "desktop",
      "type": "screenshot",
      "path": "screen.png",
      "output": {
        "as": "desktop_screenshot"
      }
    },
    {
      "action": "desktop_assert",
      "desktop": "desktop",
      "type": "screenshot",
      "path": "screen.png",
      "min_bytes": 1,
      "output": {
        "as": "desktop_screenshot_assertion"
      }
    },
    {
      "action": "desktop_capture",
      "desktop": "desktop",
      "type": "snapshot",
      "path": "snapshot.json",
      "output": {
        "as": "desktop_snapshot"
      }
    },
    {
      "action": "desktop_capture",
      "desktop": "desktop",
      "type": "observe",
      "path": "observe.json",
      "include_windows": true,
      "include_elements": false,
      "include_screenshot": true,
      "output": {
        "as": "desktop_observation"
      }
    },
    {
      "action": "close_desktop",
      "desktop": "desktop"
    }
  ]
}
