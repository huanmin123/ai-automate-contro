{
  "name": "database duckdb local analysis",
  "automation_type": "browser",
  "variables": {
    "duckdb_connection": {
      "type": "duckdb",
      "path": "output/sql/local-analysis.duckdb"
    },
    "csv_path": "test-plans/database/duckdb-local-analysis/resources/transactions.csv"
  },
  "steps": [
    {
      "action": "sql",
      "type": "execute",
      "connection": "{{duckdb_connection}}",
      "sql": "drop table if exists transactions"
    },
    {
      "action": "sql",
      "type": "execute",
      "connection": "{{duckdb_connection}}",
      "sql": "create table transactions as select * from read_csv_auto('{{csv_path}}', header=true)"
    },
    {
      "action": "sql",
      "type": "query",
      "connection": "{{duckdb_connection}}",
      "sql": "select category, count(*) as item_count, sum(amount) as total_amount from transactions group by category order by total_amount desc",
      "rows_path": "duckdb-category-summary.json",
      "result_path": "duckdb-category-summary-result.json",
      "save_as": "category_summary"
    },
    {
      "action": "sql",
      "type": "scalar",
      "connection": "{{duckdb_connection}}",
      "sql": "select round(sum(amount), 2) from transactions",
      "result_path": "duckdb-total.json",
      "save_as": "total_amount"
    },
    {
      "action": "sql",
      "type": "inspect",
      "connection": "{{duckdb_connection}}",
      "table": "transactions",
      "result_path": "duckdb-schema.json",
      "save_as": "duckdb_schema"
    },
    {
      "action": "write",
      "type": "variables",
      "path": "duckdb-local-analysis-variables.json"
    }
  ]
}
