{
  "name": "http-command-component-combo",
  "automation_type": "browser",
  "tags": [
    "http",
    "command",
    "read",
    "write",
    "foreach",
    "retry",
    "run_sub_plan",
    "integration"
  ],
  "variables": {
    "api_base_url": "http://127.0.0.1:43126"
  },
  "steps": [
    {
      "action": "command",
      "type": "run",
      "argv": [
        "python",
        "-c",
        "from pathlib import Path; import json, tempfile; p = Path(tempfile.gettempdir()) / 'aic-http-component-combo-items.json'; data = [{'id': 'alpha', 'secret': 'token-alpha', 'quantity': '2'}, {'id': 'beta', 'secret': 'token-beta', 'quantity': '5'}, {'id': 'gamma', 'secret': 'token-gamma', 'quantity': '8'}]; p.write_text(json.dumps(data, ensure_ascii=False), encoding='utf-8'); print(json.dumps({'path': str(p), 'count': len(data)}, ensure_ascii=False))"
      ],
      "stdout_type": "json",
      "output": {
        "as": "external_fixture"
      }
    },
    {
      "action": "read",
      "type": "json",
      "path": "{{external_fixture.stdout_json.path}}",
      "output": {
        "as": "items"
      }
    },
    {
      "action": "write",
      "type": "text",
      "path": "loop-ids.txt",
      "value": ""
    },
    {
      "action": "foreach",
      "items": "{{items}}",
      "item_var": "entry",
      "index_var": "entry_index",
      "steps": [
        {
          "action": "retry",
          "attempts": 2,
          "wait_seconds": 0.01,
          "steps": [
            {
              "action": "http",
              "type": "request",
              "method": "GET",
              "url": "{{api_base_url}}/flaky/{{entry.id}}",
              "query": {
                "secret": "{{entry.secret}}",
                "index": "{{entry_index}}"
              },
              "expect_status": 200,
              "body_type": "json",
              "output": {
                "as": "flaky_response"
              }
            }
          ]
        },
        {
          "action": "http",
          "type": "request",
          "method": "GET",
          "url": "{{api_base_url}}/item/{{entry.id}}",
          "query": {
            "secret": "{{entry.secret}}",
            "quantity": "{{entry.quantity}}"
          },
          "expect_status": 200,
          "body_type": "json",
          "output": {
            "as": "item_response"
          }
        },
        {
          "action": "command",
          "type": "run",
          "argv": [
            "python",
            "-c",
            "import hashlib, json, sys; payload = json.load(sys.stdin); text = '|'.join([payload['id'], payload['secret'], payload['quantity'], payload['source']]); print(json.dumps({'id': payload['id'], 'sha256': hashlib.sha256(text.encode('utf-8')).hexdigest(), 'source': payload['source']}))"
          ],
          "stdin": "{\"id\":\"{{item_response.body.id}}\",\"secret\":\"{{item_response.body.query.secret}}\",\"quantity\":\"{{item_response.body.query.quantity}}\",\"source\":\"{{item_response.body.source}}\"}",
          "stdout_type": "json",
          "output": {
            "as": "processed_item"
          }
        },
        {
          "action": "http",
          "type": "request",
          "method": "POST",
          "url": "{{api_base_url}}/aggregate",
          "json": {
            "id": "{{processed_item.stdout_json.id}}",
            "sha256": "{{processed_item.stdout_json.sha256}}",
            "source": "{{processed_item.stdout_json.source}}",
            "flaky_attempts": "{{flaky_response.body.attempts}}"
          },
          "expect_status": 200,
          "body_type": "json",
          "output": {
            "as": "aggregate_response"
          }
        },
        {
          "action": "write",
          "type": "text",
          "path": "loop-ids.txt",
          "value": "{{aggregate_response.body.id}}\n",
          "append": true
        }
      ]
    },
    {
      "action": "run_sub_plan",
      "path": "sub-plans/finalize-plan.json"
    }
  ]
}
