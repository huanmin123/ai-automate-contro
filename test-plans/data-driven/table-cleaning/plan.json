{
  "name": "table-cleaning",
  "automation_type": "browser",
  "variables": {
    "employees": [
      {
        "员工": "张三|财务",
        "状态": "A",
        "入职日期": "2026/1/5",
        "部门编码": "FIN",
        "区号": "86",
        "手机号": "13800138000",
        "备注": ""
      },
      {
        "员工": "李四|人事",
        "状态": "I",
        "入职日期": "2026-02-10",
        "部门编码": "HR",
        "区号": "86",
        "手机号": "13900139000",
        "备注": "离职"
      },
      {
        "员工": "王五|财务",
        "状态": "A",
        "入职日期": "2026.03.15",
        "部门编码": "FIN",
        "区号": "86",
        "手机号": "",
        "备注": ""
      }
    ],
    "departments": [
      {
        "部门编码": "FIN",
        "部门名称": "财务部"
      },
      {
        "部门编码": "HR",
        "部门名称": "人事部"
      }
    ],
    "raw_import": [
      {
        " 姓名 ": "赵六",
        "部门 编码": "FIN",
        "状态": "在职",
        "入职 日期": "2026/04/01",
        "部门全称": "财务 部",
        "联系电话": ""
      }
    ],
    "department_aliases": [
      {
        "部门名称": "财务 部",
        "部门编码标准": "FIN"
      },
      {
        "部门名称": "人事部",
        "部门编码标准": "HR"
      }
    ]
  },
  "steps": [
    {
      "action": "table",
      "type": "replace",
      "source": "{{employees}}",
      "values": {
        "": "未填写"
      },
      "columns": {
        "状态": {
          "A": "在职",
          "I": "离职"
        }
      },
      "output": {
        "as": "replaced_rows"
      }
    },
    {
      "action": "table",
      "type": "split_column",
      "source": "{{replaced_rows}}",
      "column": "员工",
      "separator": "|",
      "into": [
        "姓名",
        "部门短名"
      ],
      "remove_source": true,
      "output": {
        "as": "split_rows"
      }
    },
    {
      "action": "table",
      "type": "merge_columns",
      "source": "{{split_rows}}",
      "columns": [
        "区号",
        "手机号"
      ],
      "into": "联系电话",
      "separator": "-",
      "skip_empty": true,
      "output": {
        "as": "phone_rows"
      }
    },
    {
      "action": "table",
      "type": "date_parse",
      "source": "{{phone_rows}}",
      "columns": {
        "入职日期": [
          "%Y/%m/%d",
          "%Y-%m-%d",
          "%Y.%m.%d"
        ]
      },
      "output_format": "iso",
      "output": {
        "as": "dated_rows"
      }
    },
    {
      "action": "table",
      "type": "lookup",
      "source": "{{dated_rows}}",
      "right": "{{departments}}",
      "on": "部门编码",
      "values": {
        "部门名称": "部门全称"
      },
      "default": "未知",
      "output": {
        "as": "cleaned_rows"
      }
    },
    {
      "action": "table",
      "type": "normalize_headers",
      "source": "{{raw_import}}",
      "columns": {
        " 姓名 ": "姓名",
        "部门 编码": "部门编码",
        "入职 日期": "入职日期"
      },
      "output": {
        "as": "normalized_import"
      }
    },
    {
      "action": "table",
      "type": "union",
      "source": "{{cleaned_rows}}",
      "sources": [
        "{{normalized_import}}"
      ],
      "columns": [
        "姓名",
        "部门短名",
        "部门编码",
        "状态",
        "入职日期",
        "部门全称",
        "手机号",
        "联系电话",
        "备注"
      ],
      "fill_missing": "",
      "output": {
        "as": "union_rows"
      }
    },
    {
      "action": "table",
      "type": "fuzzy_lookup",
      "source": "{{union_rows}}",
      "right": "{{department_aliases}}",
      "left_on": "部门全称",
      "right_on": "部门名称",
      "values": {
        "部门编码标准": "模糊部门编码"
      },
      "default": "未知",
      "threshold": 0.8,
      "ignore_spaces": true,
      "score_column": "部门匹配分",
      "output": {
        "as": "fuzzy_rows"
      }
    },
    {
      "action": "write",
      "type": "json",
      "path": "table-cleaning.json",
      "value": {
        "rows": "{{fuzzy_rows}}"
      }
    }
  ]
}
