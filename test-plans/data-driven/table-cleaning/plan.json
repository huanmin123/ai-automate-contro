{
  "name": "table-cleaning",
  "automation_type": "browser",
  "variables": {
    "employees": [
      {
        "员工": "张三|财务",
        "状态": "A",
        "入职日期": "2026/1/5",
        "部门编码": "FIN",
        "区号": "86",
        "手机号": "13800138000",
        "备注": ""
      },
      {
        "员工": "李四|人事",
        "状态": "I",
        "入职日期": "2026-02-10",
        "部门编码": "HR",
        "区号": "86",
        "手机号": "13900139000",
        "备注": "离职"
      },
      {
        "员工": "王五|财务",
        "状态": "A",
        "入职日期": "2026.03.15",
        "部门编码": "FIN",
        "区号": "86",
        "手机号": "",
        "备注": ""
      }
    ],
    "departments": [
      {
        "部门编码": "FIN",
        "部门名称": "财务部"
      },
      {
        "部门编码": "HR",
        "部门名称": "人事部"
      }
    ]
  },
  "steps": [
    {
      "action": "table",
      "type": "replace",
      "source": "{{employees}}",
      "values": {
        "": "未填写"
      },
      "columns": {
        "状态": {
          "A": "在职",
          "I": "离职"
        }
      },
      "save_as": "replaced_rows"
    },
    {
      "action": "table",
      "type": "split_column",
      "source": "{{replaced_rows}}",
      "column": "员工",
      "separator": "|",
      "into": ["姓名", "部门短名"],
      "remove_source": true,
      "save_as": "split_rows"
    },
    {
      "action": "table",
      "type": "merge_columns",
      "source": "{{split_rows}}",
      "columns": ["区号", "手机号"],
      "into": "联系电话",
      "separator": "-",
      "skip_empty": true,
      "save_as": "phone_rows"
    },
    {
      "action": "table",
      "type": "date_parse",
      "source": "{{phone_rows}}",
      "columns": {
        "入职日期": ["%Y/%m/%d", "%Y-%m-%d", "%Y.%m.%d"]
      },
      "output_format": "iso",
      "save_as": "dated_rows"
    },
    {
      "action": "table",
      "type": "lookup",
      "source": "{{dated_rows}}",
      "right": "{{departments}}",
      "on": "部门编码",
      "values": {
        "部门名称": "部门全称"
      },
      "default": "未知",
      "save_as": "cleaned_rows"
    },
    {
      "action": "write",
      "type": "json",
      "path": "table-cleaning.json",
      "value": {
        "rows": "{{cleaned_rows}}"
      }
    }
  ]
}
