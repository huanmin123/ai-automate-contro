{
  "name": "load-csv",
  "automation_type": "browser",
  "variables": {},
  "steps": [
    {
      "action": "read",
      "type": "csv",
      "path": "resources/sample_accounts.csv",
      "output": {
        "as": "rows"
      }
    },
    {
      "action": "print",
      "message": "CSV 已加载，行数为 {{rows}}"
    },
    {
      "action": "write",
      "type": "variables",
      "path": "variables.json"
    }
  ]
}
