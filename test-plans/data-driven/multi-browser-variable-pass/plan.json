{
  "name": "multi-browser-variable-pass",
  "variables": {
    "login_url": "{{resources_file_url}}/basic_login.html"
  },
  "steps": [
    {
      "action": "open_browser",
      "name": "source",
      "headed": true,
      "slow_mo_ms": 100
    },
    {
      "action": "navigate",
      "browser": "source",
      "url": "{{login_url}}",
      "type": "goto"
    },
    {
      "action": "manual_confirm",
      "prompt": "请手动在 source 页面准备好数据，然后输入 y 继续: "
    },
    {
      "action": "extract",
      "browser": "source",
      "selector": "input[autocomplete='username']",
      "save_as": "shared_email",
      "type": "value"
    },
    {
      "action": "open_browser",
      "name": "target",
      "headed": true,
      "slow_mo_ms": 100
    },
    {
      "action": "navigate",
      "browser": "target",
      "url": "{{login_url}}",
      "type": "goto"
    },
    {
      "action": "element",
      "browser": "target",
      "selector": "input[autocomplete='username']",
      "value": "{{shared_email}}",
      "type": "fill"
    },
    {
      "action": "wait",
      "browser": "target",
      "seconds": 5
    }
  ]
}
