{
  "name": "load-excel",
  "automation_type": "browser",
  "variables": {},
  "steps": [
    {
      "action": "read",
      "type": "excel",
      "path": "resources/人员名单.xlsx",
      "sheet": "名单",
      "save_as": "employees",
      "save_meta_as": "employees_meta"
    },
    {
      "action": "table",
      "type": "filter",
      "source": "{{employees}}",
      "where": {
        "部门": "财务",
        "状态": "在职"
      },
      "save_as": "finance_people"
    },
    {
      "action": "table",
      "type": "select",
      "source": "{{finance_people}}",
      "columns": ["姓名", "部门", "手机号"],
      "rename": {
        "手机号": "电话"
      },
      "save_as": "contact_rows"
    },
    {
      "action": "write",
      "type": "json",
      "path": "finance-people.json",
      "value": {
        "rows": "{{contact_rows}}",
        "meta": "{{employees_meta}}"
      }
    },
    {
      "action": "write",
      "type": "excel",
      "path": "财务在职人员.xlsx",
      "sheet": "名单",
      "value": "{{contact_rows}}",
      "freeze_header": true,
      "auto_filter": true
    }
  ]
}
