{
  "name": "table-transform",
  "automation_type": "browser",
  "variables": {
    "transactions": [
      {
        "单号": "A001",
        "日期": "2026-06-01",
        "部门": "财务",
        "摘要": "差旅报销",
        "金额": 1200,
        "税额": 72
      },
      {
        "单号": "A002",
        "日期": "2026-06-01",
        "部门": "人事",
        "摘要": "办公用品",
        "金额": 300,
        "税额": 18
      },
      {
        "单号": "A001",
        "日期": "2026-06-02",
        "部门": "财务",
        "摘要": "差旅补贴",
        "金额": 1500,
        "税额": 90
      }
    ],
    "departments": [
      {
        "部门": "财务",
        "负责人": "王经理"
      },
      {
        "部门": "人事",
        "负责人": "赵经理"
      }
    ]
  },
  "steps": [
    {
      "action": "table",
      "type": "filter",
      "source": "{{transactions}}",
      "where": {
        "金额": {
          "gte": 1000
        },
        "摘要": {
          "contains": "差旅"
        }
      },
      "output": {
        "as": "travel_rows"
      }
    },
    {
      "action": "table",
      "type": "sort",
      "source": "{{travel_rows}}",
      "by": [
        "日期",
        "金额"
      ],
      "descending": [
        false,
        true
      ],
      "output": {
        "as": "sorted_rows"
      }
    },
    {
      "action": "table",
      "type": "dedupe",
      "source": "{{sorted_rows}}",
      "by": "单号",
      "keep": "last",
      "output": {
        "as": "unique_rows"
      }
    },
    {
      "action": "table",
      "type": "select",
      "source": "{{unique_rows}}",
      "columns": [
        "单号",
        "部门",
        "金额",
        "税额"
      ],
      "output": {
        "as": "selected_rows"
      }
    },
    {
      "action": "table",
      "type": "join",
      "source": "{{selected_rows}}",
      "right": "{{departments}}",
      "on": "部门",
      "how": "left",
      "output": {
        "as": "joined_rows"
      }
    },
    {
      "action": "table",
      "type": "add_column",
      "source": "{{joined_rows}}",
      "columns": {
        "标签": {
          "format": "{部门}-{单号}-{负责人}"
        },
        "含税金额": {
          "sum": [
            "金额",
            "税额"
          ]
        }
      },
      "output": {
        "as": "labeled_rows"
      }
    },
    {
      "action": "table",
      "type": "group",
      "source": "{{transactions}}",
      "by": "部门",
      "aggregations": {
        "笔数": {
          "count": "*"
        },
        "总金额": {
          "sum": "金额"
        },
        "平均金额": {
          "avg": "金额"
        }
      },
      "output": {
        "as": "summary_rows"
      }
    },
    {
      "action": "write",
      "type": "json",
      "path": "table-result.json",
      "value": {
        "rows": "{{labeled_rows}}",
        "summary": "{{summary_rows}}"
      }
    },
    {
      "action": "write",
      "type": "excel",
      "path": "table-transform.xlsx",
      "sheets": [
        {
          "sheet": "明细",
          "value": "{{labeled_rows}}",
          "freeze_header": true,
          "auto_filter": true,
          "table": true
        },
        {
          "sheet": "部门汇总",
          "value": "{{summary_rows}}",
          "freeze_header": true,
          "auto_filter": true,
          "table": true
        }
      ]
    }
  ]
}
