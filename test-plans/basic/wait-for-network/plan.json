{
  "name": "wait-for-network",
  "automation_type": "browser",
  "variables": {
    "network_demo_url": "data:text/html,<html><body><button id='request-btn'>Send Request</button><button id='response-btn'>Send Response</button><script>document.getElementById('request-btn').addEventListener('click',()=>fetch('https://httpbin.org/get?case=request-demo'));document.getElementById('response-btn').addEventListener('click',()=>fetch('https://httpbin.org/get?case=response-demo'));</script></body></html>"
  },
  "steps": [
    {
      "action": "open_browser",
      "name": "demo",
      "headed": false
    },
    {
      "action": "navigate",
      "browser": "demo",
      "url": "{{network_demo_url}}",
      "type": "goto"
    },
    {
      "action": "wait_for_network",
      "browser": "demo",
      "url": "https://httpbin.org/get?case=request-demo",
      "trigger": {
        "action": "element",
        "browser": "demo",
        "selector": "#request-btn",
        "type": "click"
      },
      "type": "request",
      "output": {
        "as": "request_info"
      }
    },
    {
      "action": "wait_for_network",
      "browser": "demo",
      "url": "https://httpbin.org/get?case=response-demo",
      "trigger": {
        "action": "element",
        "browser": "demo",
        "selector": "#response-btn",
        "type": "click"
      },
      "type": "response",
      "output": {
        "as": "response_info"
      }
    },
    {
      "action": "write",
      "type": "json",
      "path": "network.json",
      "value": {
        "request": "{{request_info}}",
        "response": "{{response_info}}"
      }
    }
  ]
}
