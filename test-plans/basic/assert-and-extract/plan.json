{
  "name": "assert-and-extract",
  "automation_type": "browser",
  "variables": {
    "login_url": "{{resources_file_url}}/basic_login.html"
  },
  "steps": [
    {
      "action": "open_browser",
      "name": "demo",
      "headed": true,
      "slow_mo_ms": 100
    },
    {
      "action": "navigate",
      "browser": "demo",
      "url": "{{login_url}}",
      "type": "goto"
    },
    {
      "action": "assert",
      "browser": "demo",
      "selector": "#submit-btn",
      "expected": "进入控制台",
      "type": "text"
    },
    {
      "action": "extract",
      "browser": "demo",
      "selector": "#username",
      "attribute": "placeholder",
      "type": "attribute",
      "output": {
        "as": "username_placeholder"
      }
    },
    {
      "action": "extract",
      "browser": "demo",
      "selector": "input",
      "type": "count",
      "output": {
        "as": "input_count"
      }
    },
    {
      "action": "assert",
      "browser": "demo",
      "selector": "input",
      "expected": 3,
      "type": "count"
    },
    {
      "action": "write",
      "type": "variables",
      "path": "variables.json"
    }
  ]
}
