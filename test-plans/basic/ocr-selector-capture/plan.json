{
  "name": "ocr-selector-capture",
  "variables": {},
  "steps": [
    {
      "action": "write",
      "type": "text",
      "path": "ocr-selector-capture.html",
      "value": "<html><body><div id=\"ocr-target\" style=\"display:inline-block;border:1px solid #333;padding:16px;font-size:28px;font-family:Arial;background:#fff;color:#000\">ORDER-9281</div></body></html>"
    },
    {
      "action": "open_browser",
      "name": "demo",
      "headed": false
    },
    {
      "action": "navigate",
      "browser": "demo",
      "url": "{{output_dir_file_url}}/text/ocr-selector-capture.html",
      "type": "goto"
    },
    {
      "action": "wait",
      "browser": "demo",
      "selector": "#ocr-target",
      "type": "selector"
    },
    {
      "action": "ocr_image",
      "service": "local_ocr",
      "browser": "demo",
      "selector": "#ocr-target",
      "save_as": "ocr_result",
      "save_text_as": "ocr_text"
    },
    {
      "action": "write",
      "type": "json",
      "path": "ocr-result.json",
      "value": "{{ocr_result}}"
    }
  ]
}
