{
  "name": "ocr-data-url",
  "variables": {},
  "steps": [
    {
      "action": "ocr_image",
      "service": "local_ocr",
      "path": "resources/ocr-sample.png",
      "save_as": "ocr_result",
      "save_text_as": "ocr_text"
    },
    {
      "action": "write",
      "type": "json",
      "path": "ocr-result.json",
      "value": "{{ocr_result}}"
    }
  ]
}
