{
  "name": "write-csv",
  "automation_type": "browser",
  "variables": {
    "rows": [
      {
        "email": "demo1@example.com",
        "role": "admin"
      },
      {
        "email": "demo2@example.com",
        "role": "tester"
      }
    ]
  },
  "steps": [
    {
      "action": "write",
      "type": "csv",
      "path": "accounts.csv",
      "value": "{{rows}}"
    },
    {
      "action": "read",
      "type": "csv",
      "path": "output/csv/accounts.csv",
      "output": {
        "as": "loaded_rows"
      }
    },
    {
      "action": "write",
      "type": "json",
      "path": "loaded-rows.json",
      "value": "{{loaded_rows}}"
    }
  ]
}
