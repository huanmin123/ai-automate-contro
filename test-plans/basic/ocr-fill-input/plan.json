{
  "name": "ocr-fill-input",
  "variables": {
    "captcha_image_base64": ""
  },
  "steps": [
    {
      "action": "write",
      "type": "text",
      "path": "ocr-fill-input.html",
      "value": "<html><body style=\"padding:24px;font-family:Arial\"><div style=\"margin-bottom:12px\"><img id=\"captcha-image\" alt=\"验证码图\" src=\"data:image/png;base64,{{captcha_image_base64}}\" /></div><div><input id=\"captcha-input\" type=\"text\" value=\"\" placeholder=\"请输入识别结果\" /></div></body></html>"
    },
    {
      "action": "open_browser",
      "name": "demo",
      "headed": false
    },
    {
      "action": "navigate",
      "browser": "demo",
      "url": "{{output_dir_file_url}}/text/ocr-fill-input.html",
      "type": "goto"
    },
    {
      "action": "wait",
      "browser": "demo",
      "selector": "#captcha-image",
      "type": "selector"
    },
    {
      "action": "extract",
      "browser": "demo",
      "selector": "#captcha-image",
      "attribute": "src",
      "save_as": "captcha_src",
      "type": "attribute"
    },
    {
      "action": "ocr_image",
      "service": "local_ocr",
      "data_url": "{{captcha_src}}",
      "save_as": "ocr_result",
      "save_text_as": "ocr_text"
    },
    {
      "action": "element",
      "browser": "demo",
      "selector": "#captcha-input",
      "value": "{{ocr_text}}",
      "type": "fill"
    },
    {
      "action": "assert",
      "browser": "demo",
      "selector": "#captcha-input",
      "expected": "{{ocr_text}}",
      "type": "value"
    },
    {
      "action": "write",
      "type": "json",
      "path": "ocr-result.json",
      "value": {
        "recognized_text": "{{ocr_text}}",
        "ocr_result": "{{ocr_result}}"
      }
    }
  ]
}
